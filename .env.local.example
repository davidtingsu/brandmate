# BrandMate — copy this file to .env.local and fill in your values
#
# SSL / TLS: if Node fetch fails with UNABLE_TO_GET_ISSUER_CERT_LOCALLY (common on
# corporate VPN/Mac), use `npm run dev` — it sets NODE_OPTIONS=--use-system-ca.
#   cp .env.local.example .env.local
#
# Never commit .env.local (it's in .gitignore)

# =============================================================================
# REQUIRED — provide before first run
# =============================================================================

# OpenAI — text agents, embeddings, CopilotKit runtime
# Get key: https://platform.openai.com/api-keys
# Tip: set a $15/month spending limit at https://platform.openai.com/settings/organization/limits
OPENAI_API_KEY=

# =============================================================================
# REDIS — local Docker (default) or Redis Cloud
# =============================================================================

# Local Redis Stack (docker compose up) — port 6380 avoids brew redis on 6379:
REDIS_URL=redis://localhost:6380

# Redis Cloud (production / Vercel — use in .env.vercel or GitHub Secrets):
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:PORT
#
# Vercel deploy: see docs/CI_SETUP.md (GitHub Actions auto-sync) or .env.vercel.example

# =============================================================================
# W&B WEAVE — tracing & observability (needed before Weave phase)
# =============================================================================

# Get key: https://wandb.ai/authorize
WANDB_API_KEY=

# Set to true to skip Weave tracing (use if trace upload returns 403)
# DISABLE_WEAVE=true

# Your W&B entity/project — create at https://wandb.ai or use on first weave.init
# Format: username-or-team/project-name
# Use your W&B default entity (often username-self on personal accounts), not just username
WEAVE_PROJECT=your-username-self/brandmate

# =============================================================================
# OPTIONAL — defaults are fine for hackathon / local dev
# =============================================================================

# OpenAI models (locked to cheap options — do not change to gpt-4o)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Supabase — chat sessions + post image storage (API Keys tab, not Legacy)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_STORAGE_BUCKET=post-images

# OpenAI image generation for "Post with Image"
# OPENAI_IMAGE_MODEL=gpt-image-1

# CopilotKit (only if using CopilotKit Cloud / license — skip for local BuiltInAgent)
# COPILOTKIT_LICENSE_KEY=
