# BrandMate — production env for Vercel
#   cp .env.vercel.example .env.vercel
#   Fill values, then: npm run env:push-vercel
#
# CI alternative: GitHub Repository Secrets (see docs/CI_SETUP.md)
# Never commit .env.vercel

OPENAI_API_KEY=
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_REDIS_CLOUD_HOST:PORT
WANDB_API_KEY=
WEAVE_PROJECT=your-username-self/brandmate
OPENAI_MODEL=gpt-4o-mini
OPENAI_CAROUSEL_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=post-images
OPENAI_IMAGE_MODEL=gpt-image-2
